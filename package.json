{
	"name": "dpdp-sdk",
	"version": "0.4.2",
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && node scripts/copy-styles.js && publint",
		"prepack": "svelte-kit sync && svelte-package && node scripts/copy-styles.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js"
		},
		"./styles": "./dist/styles/dpdp.css"
	},
	"files": [
		"src",
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"peerDependencies": {
		"@sveltejs/kit": "^2.5.0",
		"svelte": "^4.2.0 || ^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.5.18",
		"@sveltejs/package": "2.3.10",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/node": "^20.0.0",
		"publint": "^0.3.21",
		"svelte": "^4.2.18",
		"svelte-check": "^3.4.3",
		"typescript": "^5.1.3",
		"vite": "^5.3.4"
	},
	"main": "./dist/index.js",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"registry": "https://nexusoss.prod.angelcloud.in/repository/npm-hosted"
	},
	"pnpm": {
		"overrides": {
			"chokidar": "3.6.0"
		}
	}
}
